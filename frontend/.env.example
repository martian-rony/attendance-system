# API base URL — when running against the dev proxy (vite proxies /api to :5000), leave blank.
VITE_API_URL=
# Socket.io URL — defaults to window.location.origin (proxied in dev)
VITE_SOCKET_URL=
VITE_APP_NAME=Attendance System
# Default geofence radius in meters (used only if session doesn't specify)
VITE_DEFAULT_GEOFENCE_RADIUS=100
# Optional QR rotation period (seconds) — must match backend QR_ROTATION_SECONDS
# if the live QR display should refresh in step with the server. Leave blank to
# let the backend drive refresh timing.
VITE_QR_ROTATION_SECONDS=30
