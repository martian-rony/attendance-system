# Server Configuration
NODE_ENV=development
PORT=5000
# NOTE: API routes are mounted at /api (hardcoded in app.js). There is no
# API_PREFIX env override, so /api/v1 is intentionally NOT used.

# Database
MONGODB_URI=mongodb://localhost:27017/attendance-system
MONGODB_URI_TEST=mongodb://localhost:27017/attendance-system-test

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# QR Code signing secret (REQUIRED in production — app refuses to boot without it)
QR_CODE_SECRET=your-qr-signing-secret-change-in-production
QR_CODE_EXPIRY_MINUTES=120
QR_CODE_SIZE=300

# CORS — comma-separated list of allowed client origins (e.g. https://app.example.com)
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Geolocation
DEFAULT_GEOFENCE_RADIUS=100
MAX_GEOFENCE_RADIUS=500

# File Upload (for future use)
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email (for future use)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@attendance-system.com

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
